{
  "entities": {
    "chapter": {
      "title": "Chapter",
      "description": "A chapter of the story.",
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "description": "The chapter number."
        },
        "title": {
          "type": "string",
          "description": "The chapter title."
        },
        "content": {
          "type": "string",
          "description": "The full text content of the chapter."
        },
        "isLocked": {
          "type": "boolean",
          "description": "Whether the chapter is currently locked."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the chapter was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the chapter was last updated."
        }
      },
      "required": ["id", "title", "content", "isLocked"]
    }
  },
  "firestore": {
    "/chapters/{chapterId}": {
      "schema": "chapter",
      "description": "Collection of story chapters."
    }
  }
}
