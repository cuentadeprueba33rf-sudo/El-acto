rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: access_codes
    // Document ID: {codeId}
    // Fields:
    //   - code: string (required) - The unique code
    //   - isUsed: bool (required) - Whether it's been used
    //   - usedAt: timestamp (optional) - When it was used
    //
    // Collection: chapters
    // Document ID: {chapterId}
    // Fields:
    //   - id: number (required) - Chapter number
    //   - title: string (required) - Chapter title
    //   - content: string (required) - Chapter content
    //   - isLocked: bool (required) - Whether it's locked
    //   - createdAt: timestamp (optional)
    //   - updatedAt: timestamp (optional)
    //
    // ===============================================================

    // Collection: stories
    // Document ID: {storyId}
    // Fields:
    //   - id: string (required) - Story ID (slug)
    //   - title: string (required) - Story title
    //   - author: string (required) - Story author
    //   - description: string (required) - Story description
    //   - coverUrl: string (optional) - Story cover image URL
    //   - status: string (required) - Story status (Disponible, En Progreso, Próximamente)
    //   - genres: list (optional) - List of genres
    //   - chapters: number (optional) - Number of chapters
    //   - createdAt: timestamp (optional)
    //   - updatedAt: timestamp (optional)
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        request.auth.token.email == "samuelcasseresbx@gmail.com";
    }

    match /stories/{storyId} {
      // Public can read all stories
      allow read, list: if true;
      
      // Only admin can create, update, or delete stories
      allow create, update, delete: if isAdmin();
    }

    match /chapters/{chapterId} {
      // Public can read all chapters (to show the list and content)
      allow read, list: if true;
      
      // Only admin can create, update, or delete chapters
      allow create, update, delete: if isAdmin();
    }
  }
}
