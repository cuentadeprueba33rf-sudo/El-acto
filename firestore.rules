rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: access_codes
    // Document ID: {codeId}
    // Fields:
    //   - code: string (required) - The unique code
    //   - isUsed: bool (required) - Whether it's been used
    //   - usedAt: timestamp (optional) - When it was used
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "samuelcasseresbx@gmail.com" && request.auth.token.email_verified == true);
    }

    match /access_codes/{codeId} {
      // Anyone can read a code to check if it's valid (but we should probably restrict this to specific fields)
      // For simplicity, we allow reading if they know the codeId (which is the code itself)
      allow get: if true;
      
      // Only allow updating if the code is NOT used and they are marking it as USED
      // This is the "one-time use" logic
      allow update: if resource.data.isUsed == false 
                    && request.resource.data.isUsed == true
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isUsed', 'usedAt']);
      
      // Only admin can create or delete codes
      allow create, delete: if isAdmin();
    }
  }
}
