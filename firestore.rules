rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: access_codes
    // Document ID: {codeId}
    // Fields:
    //   - code: string (required) - The unique code
    //   - isUsed: bool (required) - Whether it's been used
    //   - usedAt: timestamp (optional) - When it was used
    //
    // Collection: chapters
    // Document ID: {chapterId}
    // Fields:
    //   - id: number (required) - Chapter number
    //   - title: string (required) - Chapter title
    //   - content: string (required) - Chapter content
    //   - isLocked: bool (required) - Whether it's locked
    //   - createdAt: timestamp (optional)
    //   - updatedAt: timestamp (optional)
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "samuelcasseresbx@gmail.com" && request.auth.token.email_verified == true);
    }

    match /chapters/{chapterId} {
      // Public can read all chapters (to show the list and content)
      allow read, list: if true;
      
      // Only admin can create, update, or delete chapters
      allow create, update, delete: if isAdmin();
    }
  }
}
